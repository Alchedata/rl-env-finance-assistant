"""
DPO Trainer — Direct Preference Optimization for continuous action spaces.

Implements DPO (Rafailov et al., 2023) adapted for continuous control:
- Collects preference pairs (obs, action_chosen, action_rejected)
- Trains policy to increase likelihood of chosen actions vs rejected actions
- Uses reference policy (frozen copy) for KL regularization

Key difference from standard DPO (discrete): We use Gaussian policy
parameterization and compute log-probabilities under the policy distribution.
"""
import os
import copy
import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader, TensorDataset
from typing import Optional

from env.financial_env import FinancialAssistantEnv, generate_dummy_data
from training.config import TrainingConfig
from training.preference_collector import PreferenceCollector


class GaussianPolicy(nn.Module):
    """
    Gaussian policy network for continuous action spaces.

    Outputs mean and log_std for a Gaussian distribution over actions.
    """

    def __init__(self, obs_dim: int, act_dim: int, hidden_sizes: list = None):
        super().__init__()
        hidden_sizes = hidden_sizes or [256, 256]

        layers = []
        in_dim = obs_dim
        for h in hidden_sizes:
            layers.extend([nn.Linear(in_dim, h), nn.ReLU()])
            in_dim = h

        self.backbone = nn.Sequential(*layers)
        self.mean_head = nn.Linear(in_dim, act_dim)
        self.log_std_head = nn.Linear(in_dim, act_dim)

        # Initialize
        self._init_weights()

    def _init_weights(self):
        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.orthogonal_(m.weight, gain=np.sqrt(2))
                nn.init.zeros_(m.bias)
        # Small init for output heads
        nn.init.orthogonal_(self.mean_head.weight, gain=0.01)
        nn.init.orthogonal_(self.log_std_head.weight, gain=0.01)

    def forward(self, obs: torch.Tensor):
        """
        Forward pass.

        Returns:
            mean: (batch, act_dim)
            log_std: (batch, act_dim)
        """
        features = self.backbone(obs)
        mean = torch.sigmoid(self.mean_head(features))  # [0, 1] for action space
        log_std = self.log_std_head(features)
        log_std = torch.clamp(log_std, -5, 2)  # prevent extreme values
        return mean, log_std

    def log_prob(self, obs: torch.Tensor, actions: torch.Tensor) -> torch.Tensor:
        """
        Compute log probability of actions under the policy given observations.

        Args:
            obs: (batch, obs_dim)
            actions: (batch, act_dim)

        Returns:
            log_prob: (batch,)
        """
        mean, log_std = self.forward(obs)
        std = torch.exp(log_std)
        dist = torch.distributions.Normal(mean, std)
        # Sum log probs across action dimensions
        log_prob = dist.log_prob(actions).sum(dim=-1)
        return log_prob

    def get_action(self, obs: np.ndarray, deterministic: bool = False) -> np.ndarray:
        """Get action for a single observation (for evaluation)."""
        with torch.no_grad():
            obs_t = torch.FloatTensor(obs).unsqueeze(0)
            mean, log_std = self.forward(obs_t)
            if deterministic:
                action = mean.squeeze(0).numpy()
            else:
                std = torch.exp(log_std)
                dist = torch.distributions.Normal(mean, std)
                action = dist.sample().squeeze(0).numpy()
        return action


class DPOTrainer:
    """
    Direct Preference Optimization trainer for continuous control.

    Pipeline:
    1. Optionally pre-train a reference policy using PPO (SB3)
    2. Collect preference pairs using PreferenceCollector
    3. Train policy using DPO loss to prefer chosen over rejected actions

    Usage:
        trainer = DPOTrainer(config)
        trainer.pretrain_reference(n_timesteps=50_000)
        trainer.collect_preferences(n_episodes=50)
        trainer.train()
        trainer.evaluate()
    """

    def __init__(self, config: TrainingConfig = None):
        self.config = config or TrainingConfig()
        self.device = torch.device(
            "cuda" if torch.cuda.is_available() and self.config.device != "cpu"
            else "cpu"
        )

        # Will be initialized later
        self.policy: Optional[GaussianPolicy] = None
        self.reference_policy: Optional[GaussianPolicy] = None
        self.preference_data: Optional[dict] = None
        self.env: Optional[FinancialAssistantEnv] = None

    def _make_env(self) -> FinancialAssistantEnv:
        """Create environment."""
        return FinancialAssistantEnv(
            df=generate_dummy_data(num_days=self.config.num_days),
            initial_balance=self.config.initial_balance,
            window_size=self.config.window_size,
            include_macro=self.config.include_macro,
            include_news=self.config.include_news,
        )

    def _init_policies(self, obs_dim: int, act_dim: int):
        """Initialize policy and reference policy."""
        self.policy = GaussianPolicy(obs_dim, act_dim).to(self.device)
        self.reference_policy = GaussianPolicy(obs_dim, act_dim).to(self.device)
        # Reference starts as a copy of the policy
        self.reference_policy.load_state_dict(copy.deepcopy(self.policy.state_dict()))
        self.reference_policy.eval()  # freeze reference

    def pretrain_reference(self, n_timesteps: int = None) -> None:
        """
        Pre-train a reference policy using PPO (SB3), then copy weights.

        Args:
            n_timesteps: Number of PPO timesteps. Uses config if None.
        """
        from training.sb3_trainer import SB3Trainer

        n = n_timesteps or self.config.total_timesteps
        pretrain_config = TrainingConfig(
            total_timesteps=n,
            num_days=self.config.num_days,
            initial_balance=self.config.initial_balance,
            window_size=self.config.window_size,
            include_macro=self.config.include_macro,
            include_news=self.config.include_news,
            verbose=self.config.verbose,
        )

        # Train PPO
        sb3_trainer = SB3Trainer("ppo", pretrain_config)
        sb3_trainer.train()

        # Extract policy weights from SB3 model
        ppo_model = sb3_trainer.model
        env = self._make_env()
        obs_dim = env.observation_space.shape[0]
        act_dim = env.action_space.shape[0]

        # Initialize our Gaussian policy
        self._init_policies(obs_dim, act_dim)

        # Note: Direct weight transfer from SB3 to our GaussianPolicy is
        # non-trivial due to different architectures. For production use,
        # consider using the SB3 policy directly. Here we initialize the
        # reference with random weights and rely on DPO training to align.
        # A more sophisticated approach would extract SB3's policy network weights.
        print("[DPO] Reference policy initialized. Collect preferences to begin DPO training.")

        sb3_trainer.close()

    def collect_preferences(
        self,
        policy_1=None,
        policy_2=None,
        n_episodes: int = 50,
    ) -> None:
        """
        Collect preference data for DPO training.

        If no policies provided, uses random policies.
        """
        env = self._make_env()
        self.env = env
        collector = PreferenceCollector(env=env)

        if policy_1 is not None and policy_2 is not None:
            collector.collect(policy_1, policy_2, n_episodes=n_episodes)
        elif self.policy is not None:
            # Self-play with current policy
            def policy_fn(obs):
                return self.policy.get_action(obs, deterministic=False)
            collector.collect_self_play(policy_fn, n_episodes=n_episodes)
        else:
            # Random policies
            def random_policy(obs):
                return env.action_space.sample()
            collector.collect_self_play(random_policy, n_episodes=n_episodes)

        self.preference_data = collector.get_dataset()
        n_pairs = len(collector)
        print(f"[DPO] Collected {n_pairs} preference pairs.")

        # Initialize policies if not done yet
        if self.policy is None:
            obs_dim = env.observation_space.shape[0]
            act_dim = env.action_space.shape[0]
            self._init_policies(obs_dim, act_dim)

    def train(self) -> dict:
        """
        Train the policy using DPO loss.

        DPO loss:
            L = -E[log σ(β * (log π(a_w|s) - log π_ref(a_w|s)
                              - log π(a_l|s) + log π_ref(a_l|s)))]

        Where a_w = chosen action, a_l = rejected action, β = regularization.

        Returns:
            dict with training stats
        """
        if self.preference_data is None or len(self.preference_data["margins"]) == 0:
            raise RuntimeError("No preference data. Call collect_preferences() first.")

        # Prepare data
        obs = torch.FloatTensor(self.preference_data["observations"]).to(self.device)
        act_chosen = torch.FloatTensor(self.preference_data["actions_chosen"]).to(self.device)
        act_rejected = torch.FloatTensor(self.preference_data["actions_rejected"]).to(self.device)

        dataset = TensorDataset(obs, act_chosen, act_rejected)
        dataloader = DataLoader(
            dataset,
            batch_size=self.config.batch_size,
            shuffle=True,
            drop_last=True,
        )

        # Optimizer
        optimizer = optim.Adam(self.policy.parameters(), lr=self.config.learning_rate)
        beta = self.config.dpo_beta
        n_epochs = self.config.dpo_n_epochs

        # Training loop
        all_losses = []
        for epoch in range(n_epochs):
            epoch_losses = []
            for batch_obs, batch_chosen, batch_rejected in dataloader:
                # Log probs under current policy
                log_pi_chosen = self.policy.log_prob(batch_obs, batch_chosen)
                log_pi_rejected = self.policy.log_prob(batch_obs, batch_rejected)

                # Log probs under reference policy (no grad)
                with torch.no_grad():
                    log_ref_chosen = self.reference_policy.log_prob(batch_obs, batch_chosen)
                    log_ref_rejected = self.reference_policy.log_prob(batch_obs, batch_rejected)

                # DPO loss
                log_ratio_chosen = log_pi_chosen - log_ref_chosen
                log_ratio_rejected = log_pi_rejected - log_ref_rejected

                if self.config.dpo_reference_free:
                    # Reference-free: just use log probs directly
                    logits = beta * (log_pi_chosen - log_pi_rejected)
                else:
                    logits = beta * (log_ratio_chosen - log_ratio_rejected)

                # DPO loss: -log(sigmoid(logits))
                loss = -torch.nn.functional.logsigmoid(logits).mean()

                optimizer.zero_grad()
                loss.backward()
                nn.utils.clip_grad_norm_(self.policy.parameters(), 1.0)
                optimizer.step()

                epoch_losses.append(loss.item())

            avg_loss = np.mean(epoch_losses)
            all_losses.append(avg_loss)

            if self.config.verbose >= 1:
                print(f"[DPO] Epoch {epoch + 1}/{n_epochs} | Loss: {avg_loss:.6f}")

        # Update reference policy to current policy (for iterative DPO)
        self.reference_policy.load_state_dict(copy.deepcopy(self.policy.state_dict()))

        # Save
        save_path = self.config.get_save_path("dpo")
        os.makedirs(os.path.dirname(save_path) or ".", exist_ok=True)
        torch.save(self.policy.state_dict(), f"{save_path}.pt")
        print(f"[DPO] Policy saved to {save_path}.pt")

        return {
            "algorithm": "dpo",
            "n_epochs": n_epochs,
            "final_loss": all_losses[-1],
            "all_losses": all_losses,
            "n_preference_pairs": len(self.preference_data["margins"]),
            "save_path": save_path,
        }

    def evaluate(self, n_episodes: int = 10, deterministic: bool = True) -> dict:
        """
        Evaluate the trained DPO policy.

        Returns:
            dict with evaluation metrics
        """
        if self.policy is None:
            raise RuntimeError("Policy not trained yet.")

        env = self.env or self._make_env()
        all_rewards = []
        all_net_worths = []
        all_returns = []
        all_drawdowns = []
        all_sharpes = []

        for ep in range(n_episodes):
            obs, info = env.reset(seed=self.config.seed + ep)
            done = False
            total_reward = 0.0
            net_worth_history = [self.config.initial_balance]
            returns_history = []

            while not done:
                action = self.policy.get_action(obs, deterministic=deterministic)
                obs, reward, terminated, truncated, info = env.step(action)
                done = terminated or truncated
                total_reward += reward

                nw = info.get("net_worth", self.config.initial_balance)
                net_worth_history.append(nw)
                if len(net_worth_history) >= 2 and net_worth_history[-2] > 0:
                    returns_history.append(
                        (net_worth_history[-1] - net_worth_history[-2])
                        / net_worth_history[-2]
                    )

            all_rewards.append(total_reward)
            all_net_worths.append(net_worth_history[-1])

            from utils.metrics import (
                calculate_cumulative_return,
                calculate_max_drawdown,
                calculate_sharpe_ratio,
            )
            all_returns.append(calculate_cumulative_return(net_worth_history))
            all_drawdowns.append(calculate_max_drawdown(net_worth_history))
            all_sharpes.append(calculate_sharpe_ratio(returns_history))

        results = {
            "algorithm": "dpo",
            "n_episodes": n_episodes,
            "mean_reward": sum(all_rewards) / n_episodes,
            "mean_net_worth": sum(all_net_worths) / n_episodes,
            "mean_return": sum(all_returns) / n_episodes,
            "mean_drawdown": sum(all_drawdowns) / n_episodes,
            "mean_sharpe": sum(all_sharpes) / n_episodes,
        }

        if self.config.verbose >= 1:
            print(f"\n--- DPO Evaluation ({n_episodes} episodes) ---")
            print(f"  Mean Reward:      {results['mean_reward']:.4f}")
            print(f"  Mean Net Worth:   {results['mean_net_worth']:.2f}")
            print(f"  Mean Return:      {results['mean_return']:.4f}")
            print(f"  Mean Max DD:      {results['mean_drawdown']:.4f}")
            print(f"  Mean Sharpe:      {results['mean_sharpe']:.4f}")

        return results

    def load(self, path: str):
        """Load a saved policy."""
        if self.policy is None:
            raise RuntimeError("Initialize policies first by calling collect_preferences().")
        self.policy.load_state_dict(torch.load(path, map_location=self.device))